# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=APP_URL

GROQ_API_KEY=GROQ_API_KEY
# GROQ endpoint/settings
GROQ_ENDPOINT=https://api.groq.com
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TIMEOUT_MS=15000
GROQ_MAX_RETRIES=2

# Canonical host used for sitemaps and metadata.
# `NEXT_PUBLIC_SITE_URL` is exposed to the client while `SITE_URL` is available server-side.
# Production: https://gitalyze.vercel.app
SITE_URL=https://localhost:3000
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# Recommendation helpers
# How long to cache AI replies (milliseconds).
RECOMMENDATION_CACHE_TTL_MS=900000
# How long to wait after a rate limit before retrying the AI.
GROQ_COOLDOWN_MS=60000
# Keep the dashboard cache aligned with the backend window.
NEXT_PUBLIC_RECOMMENDATION_CACHE_TTL_MS=900000
# Flip to "true" to always use heuristic remediation plans instead of hitting Groq.
FORCE_AI_RECS=false

# GITHUB_API_TOKEN: Optional but recommended for higher API rate limits.
# Create a personal access token (classic) on GitHub with `public_repo` scope.
# https://github.com/settings/tokens
GITHUB_API_TOKEN=GITHUB_API_TOKEN
