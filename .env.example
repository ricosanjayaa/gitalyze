# Canonical host used for sitemaps and metadata.
# `NEXT_PUBLIC_SITE_URL` is exposed to the client while `SITE_URL` is available server-side.
# Production: https://gitalyze.vercel.app
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Groq (AI recommendations)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TIMEOUT_MS=15000
GROQ_MAX_RETRIES=2

# Recommendation helpers
RECOMMENDATION_CACHE_TTL_MS=900000
GROQ_COOLDOWN_MS=60000
NEXT_PUBLIC_RECOMMENDATION_CACHE_TTL_MS=900000
FORCE_AI_RECS=false

# GitHub API token (optional, recommended for higher API rate limits)
# https://github.com/settings/tokens
GITHUB_API_TOKEN=
